// =============================================================================
// Medical Platform - Prisma Schema
// Architecture: Clean, scalable, production-ready
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum Role {
  CLIENT
  DOCTOR
  FACILITY
  ADMIN
}

enum ApprovalStatus {
  PENDING
  DOCUMENTS_REVIEW
  APPROVED
  REJECTED
}

enum FacilityType {
  MEDICAL_CENTER
  LABORATORY
  SCIENTIFIC_INSTITUTE
  UNIVERSITY
  MEDICAL_COLLEGE
  HOSPITAL
  CLINIC
  PHARMACY
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum AppointmentType {
  IN_PERSON
  ONLINE
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum PublicationStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PublicationType {
  ARTICLE
  RESEARCH
  CASE_STUDY
  ANNOUNCEMENT
}

// =============================================================================
// AUTH & USERS
// =============================================================================

model User {
  id            String    @id @default(uuid())
  email         String?   @unique
  emailVerified DateTime?
  phone         String?   @unique
  passwordHash  String?
  role          Role      @default(CLIENT)
  isActive      Boolean   @default(true)

  // Pi Network
  piUid         String?   @unique
  piUsername    String?   @unique

  // Soft delete
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  clientProfile   ClientProfile?
  doctorProfile   DoctorProfile?
  facilityProfile FacilityProfile?
  accounts        Account[]
  sessions        Session[]
  reviews         Review[]
  appointments    Appointment[]   @relation("ClientAppointments")
  notifications   Notification[]

  @@index([email])
  @@index([piUid])
  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

// NextAuth - Accounts
model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

// NextAuth - Sessions
model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// NextAuth - Verification Tokens
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// =============================================================================
// CLIENT PROFILE
// =============================================================================

model ClientProfile {
  id          String    @id @default(uuid())
  userId      String    @unique
  firstName   String
  lastName    String
  dateOfBirth DateTime?
  gender      String?
  avatarUrl   String?
  address     String?
  city        String?
  country     String    @default("SA")

  // Medical
  bloodType   String?
  allergies   String[]
  chronicDiseases String[]

  // Soft delete
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deletedAt])
  @@map("client_profiles")
}

// =============================================================================
// DOCTOR PROFILE
// =============================================================================

model DoctorProfile {
  id                    String         @id @default(uuid())
  userId                String         @unique
  firstName             String
  lastName              String
  avatarUrl             String?
  bio                   String?
  gender                String?
  dateOfBirth           DateTime?

  // Professional
  specialization        String
  subSpecialization     String?
  yearsOfExperience     Int            @default(0)
  languages             String[]       @default(["ar"])

  // License
  licenseNumber         String         @unique
  licenseImageUrl       String
  licenseExpiryDate     DateTime?
  licenseIssuingCountry String         @default("SA")

  // Approval
  approvalStatus        ApprovalStatus @default(PENDING)
  approvalNotes         String?
  approvedAt            DateTime?
  approvedBy            String?        // Admin userId

  // Pi KYC
  piKycVerified         Boolean        @default(false)

  // Location (for independent doctors)
  city                  String?
  country               String         @default("SA")
  address               String?
  consultationFee       Decimal?       @db.Decimal(10, 2)

  // Stats (denormalized for performance)
  totalReviews          Int            @default(0)
  averageRating         Decimal        @default(0) @db.Decimal(3, 2)
  totalAppointments     Int            @default(0)

  // Soft delete
  deletedAt             DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  // Relations
  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentials   DoctorCredential[]
  facilities    DoctorFacility[]
  availability  Availability[]
  appointments  Appointment[]          @relation("DoctorAppointments")
  reviews       Review[]
  publications  Publication[]

  @@index([userId])
  @@index([specialization])
  @@index([approvalStatus])
  @@index([licenseNumber])
  @@index([city])
  @@index([deletedAt])
  @@map("doctor_profiles")
}

// شهادات الطبيب العلمية
model DoctorCredential {
  id           String    @id @default(uuid())
  doctorId     String
  title        String    // اسم الشهادة
  institution  String    // الجامعة / المعهد
  country      String
  year         Int
  documentUrl  String    // رابط الشهادة المرفوعة
  isVerified   Boolean   @default(false)
  verifiedAt   DateTime?

  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  doctor DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([deletedAt])
  @@map("doctor_credentials")
}

// علاقة Many-to-Many بين الطبيب والمنشأة
model DoctorFacility {
  id           String    @id @default(uuid())
  doctorId     String
  facilityId   String
  role         String?   // مثلاً: استشاري، مقيم
  startDate    DateTime  @default(now())
  endDate      DateTime?
  isActive     Boolean   @default(true)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  doctor   DoctorProfile   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  facility FacilityProfile @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@unique([doctorId, facilityId])
  @@index([doctorId])
  @@index([facilityId])
  @@map("doctor_facilities")
}

// =============================================================================
// FACILITY PROFILE
// =============================================================================

model FacilityProfile {
  id               String         @id @default(uuid())
  userId           String         @unique
  name             String
  type             FacilityType
  description      String?
  logoUrl          String?
  coverUrl         String?

  // License
  licenseNumber    String         @unique
  licenseDocUrl    String
  licenseExpiryDate DateTime?

  // Approval
  approvalStatus   ApprovalStatus @default(PENDING)
  approvalNotes    String?
  approvedAt       DateTime?
  approvedBy       String?

  // Contact
  phone            String?
  email            String?
  website          String?

  // Location
  address          String
  city             String
  country          String         @default("SA")
  latitude         Decimal?       @db.Decimal(10, 8)
  longitude        Decimal?       @db.Decimal(11, 8)

  // Stats
  totalReviews     Int            @default(0)
  averageRating    Decimal        @default(0) @db.Decimal(3, 2)

  // Soft delete
  deletedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  // Relations
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctors      DoctorFacility[]
  appointments Appointment[]    @relation("FacilityAppointments")
  reviews      Review[]
  availability Availability[]

  @@index([userId])
  @@index([type])
  @@index([approvalStatus])
  @@index([city])
  @@index([licenseNumber])
  @@index([deletedAt])
  @@map("facility_profiles")
}

// =============================================================================
// AVAILABILITY
// =============================================================================

model Availability {
  id          String    @id @default(uuid())
  doctorId    String?
  facilityId  String?
  dayOfWeek   DayOfWeek
  startTime   String    // "09:00"
  endTime     String    // "17:00"
  slotMinutes Int       @default(30)
  isActive    Boolean   @default(true)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  doctor   DoctorProfile?   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  facility FacilityProfile? @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([facilityId])
  @@map("availabilities")
}

// =============================================================================
// APPOINTMENTS
// =============================================================================

model Appointment {
  id          String            @id @default(uuid())
  clientId    String
  doctorId    String?
  facilityId  String?
  type        AppointmentType   @default(IN_PERSON)
  status      AppointmentStatus @default(PENDING)

  scheduledAt DateTime
  duration    Int               @default(30) // دقائق
  notes       String?           // ملاحظات العميل
  reason      String?           // سبب الزيارة

  // Results
  doctorNotes    String?        // ملاحظات الطبيب بعد الموعد
  cancelReason   String?
  cancelledBy    String?        // userId

  // Payment
  fee         Decimal?          @db.Decimal(10, 2)
  isPaid      Boolean           @default(false)
  paidAt      DateTime?

  // Soft delete
  deletedAt   DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relations
  client   User             @relation("ClientAppointments", fields: [clientId], references: [id])
  doctor   DoctorProfile?   @relation("DoctorAppointments", fields: [doctorId], references: [id])
  facility FacilityProfile? @relation("FacilityAppointments", fields: [facilityId], references: [id])
  review   Review?

  @@index([clientId])
  @@index([doctorId])
  @@index([facilityId])
  @@index([status])
  @@index([scheduledAt])
  @@index([deletedAt])
  @@map("appointments")
}

// =============================================================================
// REVIEWS
// =============================================================================

model Review {
  id          String    @id @default(uuid())
  clientId    String
  doctorId    String?
  facilityId  String?
  appointmentId String? @unique  // مرتبط بموعد مكتمل

  rating      Int       // 1-5
  comment     String?
  isVisible   Boolean   @default(true)

  // Soft delete
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  client      User             @relation(fields: [clientId], references: [id])
  doctor      DoctorProfile?   @relation(fields: [doctorId], references: [id])
  facility    FacilityProfile? @relation(fields: [facilityId], references: [id])
  appointment Appointment?     @relation(fields: [appointmentId], references: [id])

  @@index([clientId])
  @@index([doctorId])
  @@index([facilityId])
  @@index([rating])
  @@index([deletedAt])
  @@map("reviews")
}

// =============================================================================
// PUBLICATIONS (قابل للتوسع)
// =============================================================================

model Publication {
  id          String            @id @default(uuid())
  doctorId    String
  title       String
  summary     String?
  content     String?
  type        PublicationType   @default(ARTICLE)
  status      PublicationStatus @default(DRAFT)
  tags        String[]
  coverUrl    String?
  publishedAt DateTime?

  // Stats
  viewCount   Int               @default(0)
  likeCount   Int               @default(0)

  // Soft delete
  deletedAt   DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  doctor DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([type])
  @@index([status])
  @@index([publishedAt])
  @@index([deletedAt])
  @@map("publications")
}

// =============================================================================
// NOTIFICATIONS
// =============================================================================

model Notification {
  id        String    @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String    // APPOINTMENT_CONFIRMED, REVIEW_APPROVED, etc.
  data      Json?     // بيانات إضافية
  isRead    Boolean   @default(false)
  readAt    DateTime?

  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}
