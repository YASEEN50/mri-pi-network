// =============================================================================
// VERIFICATION SYSTEM (نظام التحقق من الأطباء)
// =============================================================================

enum VerificationStatus {
  UNVERIFIED
  PENDING
  AI_APPROVED
  AI_REJECTED
  VERIFIED        // قبول بشري نهائي
  REJECTED        // رفض بشري نهائي
}

enum VerificationStage {
  UPLOAD_CERTIFICATE
  FACE_COMPARE
  AI_DECISION
  ADMIN_REVIEW
  FINAL_DECISION
}

enum QueueStatus {
  WAITING
  IN_REVIEW
  COMPLETED
}

enum CertificateStatus {
  PENDING_OCR
  OCR_DONE
  AI_APPROVED
  AI_REJECTED
  HUMAN_APPROVED
  HUMAN_REJECTED
}

enum MatchStatus {
  PENDING
  MATCHED
  NOT_MATCHED
}

enum AdminRole {
  SUPER_ADMIN
  VERIFICATION_ADMIN
  VIEWER
}

// تفاصيل التحقق من الطبيب
model DoctorVerification {
  id                    String             @id @default(uuid())
  doctorId              String             @unique
  // حالة التحقق الكلية
  verificationStatus    VerificationStatus @default(UNVERIFIED)
  currentStage          VerificationStage  @default(UPLOAD_CERTIFICATE)
  // التحقق من الوجه
  faceVerificationStatus MatchStatus       @default(PENDING)
  selfieImageUrl        String?
  idImageUrl            String?
  faceMatchConfidence   Float?
  // درجة الثقة الكلية
  overallConfidence     Float?
  // محاولات الرفع
  uploadAttempts        Int                @default(0)
  // ملاحظات الرفض
  rejectionReason       String?

  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  doctor                DoctorProfile      @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  certificates          DoctorCertificate[]
  queueEntry            VerificationQueue?

  @@index([verificationStatus])
  @@index([doctorId])
  @@map("doctor_verifications")
}

// شهادات الطبيب للتحقق
model DoctorCertificate {
  id               String            @id @default(uuid())
  verificationId   String
  imageUrl         String
  // نتائج OCR
  extractedText    String?           @db.Text
  extractedName    String?
  extractedSpecialty String?
  extractedIssueDate String?
  extractedExpiryDate String?
  extractedIssuer  String?
  // مطابقة الاسم
  nameMatchStatus  MatchStatus       @default(PENDING)
  nameMatchScore   Float?
  // نتائج AI
  aiConfidence     Float?
  aiStatus         MatchStatus       @default(PENDING)
  aiNotes          String?
  // مراجعة بشرية
  humanStatus      MatchStatus       @default(PENDING)
  humanNotes       String?
  reviewedBy       String?
  reviewedAt       DateTime?
  // الحالة الكلية
  status           CertificateStatus @default(PENDING_OCR)

  createdAt        DateTime          @default(now())

  verification     DoctorVerification @relation(fields: [verificationId], references: [id], onDelete: Cascade)

  @@index([verificationId])
  @@index([status])
  @@map("doctor_certificates")
}

// قائمة انتظار المراجعة البشرية
model VerificationQueue {
  id               String       @id @default(uuid())
  verificationId   String       @unique
  priority         Int          @default(5)   // 1 = عالي, 10 = منخفض
  assignedTo       String?
  status           QueueStatus  @default(WAITING)
  notes            String?

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  verification     DoctorVerification @relation(fields: [verificationId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([priority])
  @@map("verification_queue")
}

// إعدادات النظام
model SystemConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?

  updatedAt   DateTime @updatedAt

  @@map("system_configs")
}

// أدوار المشرفين
model AdminProfile {
  id        String    @id @default(uuid())
  userId    String    @unique
  role      AdminRole @default(VIEWER)
  isActive  Boolean   @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_profiles")
}

// =============================================================================
// MEDICAL RECORDS (السجل الطبي الإلكتروني)
// =============================================================================

enum RecordType {
  PRESCRIPTION       // وصفة طبية
  LAB_RESULT         // نتيجة تحليل
