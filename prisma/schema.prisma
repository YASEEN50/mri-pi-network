// =============================================================================
// ADMIN TASKS & PERMISSIONS (مهام وصلاحيات الأدمن)
// =============================================================================

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model AdminTask {
  id          String       @id @default(uuid())
  assignedTo  String
  assignedBy  String
  title       String
  description String?      @db.Text
  category    String       // VERIFICATION / MODERATION / SUPPORT / OTHER
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  completedAt DateTime?
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  admin       User         @relation("TasksAssigned", fields: [assignedTo], references: [id])
  assigner    User         @relation("TasksCreated",  fields: [assignedBy],  references: [id])

  @@index([assignedTo])
  @@index([status])
  @@index([priority])
  @@map("admin_tasks")
}

model AdminPermission {
  id          String   @id @default(uuid())
  adminId     String
  permission  String   // canApproveDoctor / canModeratePosts / canManageUsers / etc
  granted     Boolean  @default(true)
  grantedBy   String
  grantedAt   DateTime @default(now())

  admin       User     @relation("AdminPermissions", fields: [adminId], references: [id], onDelete: Cascade)

  @@unique([adminId, permission])
  @@map("admin_permissions")
}

// =============================================================================
// VERIFICATION SYSTEM v2 — Production-Grade
// =============================================================================

model VerificationSession {
  id                String    @id @default(uuid())
  doctorId          String
  userId            String

  currentState      String    @default("UNVERIFIED")
  // UNVERIFIED | LICENSE_UPLOADED | CREDENTIALS_UPLOADED |
  // FACE_SUBMITTED | FRAUD_CHECK | SCORING | ADMIN_REVIEW |
  // APPROVED | REJECTED | EXPIRED | REVERIFY_REQUIRED

  attemptNumber     Int       @default(1)
  licenseExpiryDate DateTime?
  rejectionReason   String?
  // Fraud Intelligence fields
  ipAddress         String?
  deviceId          String?
  userAgent         String?
  rejectedBy        String?
  rejectedAt        DateTime?
  isActive          Boolean   @default(true)
  startedAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  completedAt       DateTime?

  doctor     DoctorProfile          @relation("DoctorVerificationSessions", fields: [doctorId], references: [id], onDelete: Cascade)
  user       User                   @relation("UserVerificationSessions",   fields: [userId],   references: [id], onDelete: Cascade)
  documents  VerificationDocument[]
  jobs        JobTracking[]
  fraudChecks       FraudCheck[]       @relation("SessionFraudChecks")
  score             VerificationScore?  @relation("SessionScore")
  faceVerifications FaceVerification[]  @relation("SessionFaceVerifications")

  @@index([doctorId])
  @@index([currentState, updatedAt(sort: Desc)])
  @@index([licenseExpiryDate])
  @@map("verification_sessions")
}

model VerificationDocument {
  id            String   @id @default(uuid())
  sessionId     String
  doctorId      String
  docType       String
  // CREDENTIAL | LICENSE | DATAFLOW | SELFIE | ID_DOCUMENT
  subType       String?  // BACHELOR | MASTER | FELLOWSHIP (للشهادة الجامعية)
  legalName     String?  // الاسم كما في الشهادة / الهوية
  title         String?  // وصف إضافي

  storageKey    String
  storageBucket String   @default("medical-verify")
  mimeType      String
  fileSizeBytes Int
  pHash         String?
  sha256Hash    String?
  isProcessed   Boolean  @default(false)
  isFlagged     Boolean  @default(false)
  flagReason    String?
  forensicsScore   Int?
  forensicsSignals Json?
  createdAt     DateTime @default(now())

  session   VerificationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  ocrResult   OcrResult?
  fraudRefs   FraudReference[] @relation("DocFraudRef")
  fraudChecks FraudCheck[]     @relation("DocFraudChecks")

  @@index([sessionId])
  @@index([pHash])
  @@index([sha256Hash])
  @@index([doctorId, docType])
  @@index([forensicsScore])
  @@map("verification_documents")
}

model OcrResult {
  id                  String    @id @default(uuid())
  documentId          String    @unique
  sessionId           String
  extractedName       String?
  licenseNumber       String?
  specialty           String?
  expiryDate          DateTime?
  issueDate           DateTime?
  confidenceScore     Decimal   @db.Decimal(5, 2)
  nameMatchScore      Decimal?  @db.Decimal(5, 2)
  nameMatchStatus     String?
  // MATCHED | PARTIAL | MISMATCH | UNKNOWN
  rawText             String?   @db.Text
  isManuallyVerified  Boolean   @default(false)
  verifiedBy          String?
  createdAt           DateTime  @default(now())

  document VerificationDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([licenseNumber])
  @@map("ocr_results")
}

model JobTracking {
  id             String    @id @default(uuid())
  sessionId      String?
  doctorId       String?
  jobType        String
  // ocr-processing | face-comparison | fraud-check |
  // score-calculation | admin-notification | license-expiry-check
  queueJobId     String?
  status         String    @default("pending")
  // pending | processing | completed | failed | dead
  attempts       Int       @default(0)
  maxAttempts    Int       @default(3)
  lastError      String?
  lastErrorAt    DateTime?
  result         Json?
  idempotencyKey String?   @unique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  completedAt    DateTime?

  session VerificationSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([status, jobType, createdAt(sort: Desc)])
  @@index([sessionId])
  @@map("job_tracking")
}

model IdempotencyKey {
  id               String   @id @default(uuid())
  doctorUserId     String
  step             String
  // LICENSE_UPLOAD | CREDENTIALS_UPLOAD | FACE_SUBMISSION | ADMIN_DECISION
  idempotencyKey   String   @unique
  responseStatus   Int      @default(200)
  responseSnapshot Json     @default("{}")
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  @@unique([doctorUserId, step])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

model AuditLog {
  id            String   @id @default(uuid())
  actorId       String
  actorRole     String
  // DOCTOR | ADMIN | OWNER | SYSTEM
  action        String
  targetType    String
  targetId      String?
  payload       Json     @default("{}")
  ipAddress     String?
  userAgent     String?
  hmacSignature String
  createdAt     DateTime @default(now())

  @@index([actorId, createdAt(sort: Desc)])
  @@index([targetId, createdAt(sort: Desc)])
  @@index([action,   createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

// =============================================================================
// FACE VERIFICATION (نتائج مقارنة الوجه)
// =============================================================================

model FaceVerification {
  id            String   @id @default(uuid())
  sessionId     String
  doctorId      String
  selfieDocId   String
  idDocId       String
  matchScore    Float    @default(0)
  confidence    String   @default("LOW") // HIGH | MEDIUM | LOW | UNDETECTABLE
  facesDetected Boolean  @default(false)
  serviceUsed   String   @default("unknown")
  rawResponse   Json     @default("{}")
  createdAt     DateTime @default(now())

  session VerificationSession @relation("SessionFaceVerifications", fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([doctorId])
  @@map("face_verifications")
}

// =============================================================================
// FRAUD DETECTION + SCORE ENGINE
// =============================================================================

model FraudReference {
  id          String   @id @default(uuid())
  doctorId    String
  documentId  String
  imageType   String   // LICENSE | CREDENTIAL | SELFIE | ID_DOCUMENT
  pHash       String
  sha256Hash  String   @unique
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  doctor   DoctorProfile       @relation("DoctorFraudRefs", fields: [doctorId],   references: [id], onDelete: Cascade)
  document VerificationDocument @relation("DocFraudRef",    fields: [documentId], references: [id], onDelete: Cascade)

  @@index([pHash])
  @@index([isActive, imageType])
  @@map("fraud_references")
}

model FraudCheck {
  id               String   @id @default(uuid())
  sessionId        String
  doctorId         String
  documentId       String
  checkType        String
  // PHASH_IMAGE | LICENSE_NUMBER | SHA256_EXACT | METADATA_ANOMALY
  isFlagged        Boolean  @default(false)
  matchedDoctorId  String?
  similarityScore  Decimal? @db.Decimal(5, 2)
  riskFlags        Json     @default("[]")
  isResolved       Boolean  @default(false)
  resolvedBy       String?
  resolutionNotes  String?
  resolvedAt       DateTime?
  createdAt        DateTime @default(now())

  session        VerificationSession  @relation("SessionFraudChecks",  fields: [sessionId],  references: [id], onDelete: Cascade)
  doctor         DoctorProfile        @relation("DoctorFraudChecks",   fields: [doctorId],   references: [id], onDelete: Cascade)
  document       VerificationDocument @relation("DocFraudChecks",      fields: [documentId], references: [id], onDelete: Cascade)
  matchedDoctor  DoctorProfile?       @relation("MatchedDoctorFrauds", fields: [matchedDoctorId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([isFlagged, createdAt(sort: Desc)])
  @@index([doctorId])
  @@map("fraud_checks")
}

model VerificationScore {
  id               String   @id @default(uuid())
  sessionId        String   @unique
  doctorId         String
  ocrConfidence    Decimal  @default(0) @db.Decimal(5, 2)
  faceMatchScore   Decimal  @default(0) @db.Decimal(5, 2)
  documentClarity  Decimal  @default(0) @db.Decimal(5, 2)
  fraudRiskScore   Decimal  @default(0) @db.Decimal(5, 2)
  finalScore       Decimal  @default(0) @db.Decimal(5, 2)
  riskLevel        String   @default("HIGH") // LOW | MEDIUM | HIGH
  scoreBreakdown   Json     @default("{}")
  algorithmVersion String   @default("v1")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  session VerificationSession @relation("SessionScore", fields: [sessionId], references: [id], onDelete: Cascade)
  doctor  DoctorProfile       @relation("DoctorScores",  fields: [doctorId],  references: [id], onDelete: Cascade)

  @@index([riskLevel, finalScore(sort: Desc)])
  @@map("verification_scores")
}

// =============================================================================
// FRAUD INTELLIGENCE LAYER
// =============================================================================

// ── DeviceFingerprint ─────────────────────────────────────────────────────────

model DeviceFingerprint {
  id                String    @id @default(uuid())
  deviceId          String    @unique
  firstSeenAt       DateTime  @default(now())
  lastSeenAt        DateTime  @default(now())
  riskLevel         String    @default("LOW")   // LOW | MEDIUM | HIGH
  linkedUsersCount  Int       @default(1)
  totalAttempts     Int       @default(1)
  failedAttempts    Int       @default(0)
  metadata          Json      @default("{}")     // user-agent, platform, etc.

  users             DeviceUser[]
  fraudEvents       FraudEvent[]  @relation("DeviceFraudEvents")

  @@index([riskLevel])
  @@index([linkedUsersCount])
  @@map("device_fingerprints")
}

// ── DeviceUser (many-to-many: device ↔ user) ─────────────────────────────────

model DeviceUser {
  id         String   @id @default(uuid())
  deviceId   String
  userId     String
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  device DeviceFingerprint @relation(fields: [deviceId], references: [deviceId], onDelete: Cascade)

  @@unique([deviceId, userId])
  @@index([userId])
  @@map("device_users")
}

// ── IPReputation ──────────────────────────────────────────────────────────────

model IPReputation {
  id              String   @id @default(uuid())
  ipAddress       String   @unique
  requestCount    Int      @default(1)
  failedAttempts  Int      @default(0)
  riskLevel       String   @default("LOW")   // LOW | MEDIUM | HIGH
  firstSeenAt     DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  isBanned        Boolean  @default(false)
  bannedAt        DateTime?
  banReason       String?
  metadata        Json     @default("{}")

  fraudEvents FraudEvent[] @relation("IPFraudEvents")

  @@index([riskLevel])
  @@index([isBanned])
  @@map("ip_reputations")
}

// ── FraudEvent ────────────────────────────────────────────────────────────────

enum FraudEventType {
  MULTI_ACCOUNT_DEVICE    // نفس الجهاز لأكثر من 3 مستخدمين
  HIGH_FREQUENCY_ATTEMPT  // محاولات متكررة سريعة
  AUTOMATION_SUSPECTED    // سلوك بوت (uploads متقاربة جداً)
  SHARED_DEVICE           // جهاز مشترك بين مستخدمين
  IP_FLOOD                // flood من نفس الـ IP
  RAPID_RESUBMISSION      // إعادة تقديم سريعة بعد الرفض
  SUSPICIOUS_UA           // User-Agent مشبوه
}

model FraudEvent {
  id        String         @id @default(uuid())
  type      FraudEventType
  userId    String
  sessionId String?
  ipAddress String?
  deviceId  String?
  severity  String         @default("MEDIUM")  // LOW | MEDIUM | HIGH | CRITICAL
  metadata  Json           @default("{}")
  resolved  Boolean        @default(false)
  resolvedBy String?
  resolvedAt DateTime?
  createdAt DateTime       @default(now())

  ipReputation    IPReputation?       @relation("IPFraudEvents",     fields: [ipAddress], references: [ipAddress])
  deviceFingerprint DeviceFingerprint? @relation("DeviceFraudEvents", fields: [deviceId],  references: [deviceId])

  @@index([userId])
  @@index([type])
  @@index([severity, createdAt(sort: Desc)])
  @@index([sessionId])
  @@map("fraud_events")
}

