// =============================================================================
// APPOINTMENT REMINDERS (تذكيرات المواعيد)
// =============================================================================

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

model AppointmentReminder {
  id            String         @id @default(uuid())
  appointmentId String
  sendAt        DateTime
  type          String         // "24h" | "2h" | "custom"
  status        ReminderStatus @default(PENDING)
  sentAt        DateTime?
  error         String?
  createdAt     DateTime       @default(now())

  appointment   Appointment    @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([sendAt, status])
  @@index([appointmentId])
  @@map("appointment_reminders")
}

// =============================================================================
// CONTENT MODERATION (مراقبة المحتوى)
// =============================================================================

enum ReportType {
  INAPPROPRIATE_CONTENT
  FAKE_INFORMATION
  SPAM
  HARASSMENT
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  ACTION_TAKEN
  DISMISSED
}

enum ContentType {
  PUBLICATION
  REVIEW
  CHAT_MESSAGE
  PROFILE
}

model ContentReport {
  id          String        @id @default(uuid())
  reporterId  String
  contentType ContentType
  contentId   String
  reason      ReportType
  description String?
  status      ReportStatus  @default(PENDING)
  reviewedBy  String?
  reviewNotes String?
  reviewedAt  DateTime?
  actionTaken String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  reporter    User          @relation("ReportsMade", fields: [reporterId], references: [id])

  @@index([status])
  @@index([contentType])
  @@index([reporterId])
  @@map("content_reports")
