// =============================================================================
// Medical Platform - Prisma Schema
// Architecture: Clean, scalable, production-ready
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum OnCallShiftType {
  MORNING
  EVENING
  NIGHT
  FULL_DAY
}

enum Role {
  CLIENT
  DOCTOR
  FACILITY
  ADMIN
  OWNER
}

enum ApprovalStatus {
  PENDING
  DOCUMENTS_REVIEW
  APPROVED
  REJECTED
}

enum FacilityType {
  MEDICAL_CENTER
  LABORATORY
  SCIENTIFIC_INSTITUTE
  UNIVERSITY
  MEDICAL_COLLEGE
  HOSPITAL
  CLINIC
  PHARMACY
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum AppointmentType {
  IN_PERSON
  ONLINE
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum PublicationStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum PublicationType {
  ARTICLE
  RESEARCH
  CASE_STUDY
  ANNOUNCEMENT
  TIP
}

enum PaidAdStatus {
  PENDING_PAYMENT
  PENDING_REVIEW
  ACTIVE
  PAUSED
  EXPIRED
  REJECTED
}

enum AdPlan {
  WEEKLY
  MONTHLY
}

enum PaidAdPlacement {
  HOME_SIDEBAR
}

// أنواع البريميو
enum PremioType {
  MONTHLY
  YEARLY
  LIFETIME
  FREE_GIFT   // منحة مجانية من المالك
}

// حالة البريميو
enum PremioStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

// سياسة دفع الطبيب
enum PaymentPolicy {
  PAY_BEFORE_BOOKING    // دفع كامل قبل الحجز
  DEPOSIT_AND_PAY_LATER // إيداع + دفعة لاحقة
  PAY_ON_SERVICE        // دفع بعد الخدمة (افتراضي)
}

// نوع المعاملة المالية
enum TransactionType {
  PREMIO_PURCHASE   // شراء بريميو
  APPOINTMENT_FEE   // رسوم موعد
  INSTANT_CONSULT   // استشارة فورية
  DEPOSIT           // إيداع
  FINAL_PAYMENT     // دفعة نهائية
  REFUND            // استرداد
  REFERRAL_REWARD   // مكافأة إحالة طبيب
  PAID_AD           // إعلان مدفوع
  DOCTOR_WITHDRAWAL // سحب مستحقات طبيب
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
  FAILED
}

// حالة المعاملة المالية
enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// نوع نشاط السجل
enum ActivityType {
  CREATE_ADMIN
  REMOVE_ADMIN
  GIVE_FREE_PREMIO
  REVOKE_PREMIO
  DELETE_USER
  APPROVE_DOCTOR
  REJECT_DOCTOR
  BAN_USER
  UNBAN_USER
  CHANGE_PREMIO_PRICES
  APPROVE_FACILITY
  REJECT_FACILITY
  // Verification
  UPLOAD_CERTIFICATE
  FACE_COMPARE
  AI_DECISION
  ADMIN_REVIEW_APPROVE
  ADMIN_REVIEW_REJECT
  SUBMIT_VERIFICATION
}

// =============================================================================
// AUTH & USERS
// =============================================================================

model User {
  id            String    @id @default(uuid())
  email         String?   @unique
  emailVerified DateTime?
  phone         String?   @unique
  passwordHash  String?
  role          Role      @default(CLIENT)
  isActive      Boolean   @default(true)

  // Pi Network
  piUid         String?   @unique
  piUsername    String?   @unique

  // Soft delete
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // MFA (admin/owner — TOTP)
  mfaEnabled     Boolean   @default(false)
  mfaSecret      String?   @db.Text
  mfaBackupCodes String[]  @default([])

  // Relations
  clientProfile   ClientProfile?
  doctorProfile   DoctorProfile?
  facilityProfile FacilityProfile?
  adminProfile    AdminProfile?
  accounts        Account[]
  sessions        Session[]
  reviews         Review[]
  appointments    Appointment[]     @relation("ClientAppointments")
  notifications   Notification[]
  premios         Premio[]
  transactions    Transaction[]     @relation("UserTransactions")
  activityLogs    ActivityLog[]     @relation("ActorLogs")

  @@index([email])
  @@index([piUid])
  @@index([role])
  @@index([deletedAt])
  reportsMade       ContentReport[]   @relation("ReportsMade")
  tasksAssigned     AdminTask[]       @relation("TasksAssigned")
  tasksCreated      AdminTask[]       @relation("TasksCreated")
  adminPermissions  AdminPermission[] @relation("AdminPermissions")
  verificationSessions VerificationSession[] @relation("UserVerificationSessions")
  withdrawalRequests   WithdrawalRequest[]   @relation("UserWithdrawals")

  @@map("users")
}

// NextAuth - Accounts
model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

// NextAuth - Sessions
model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// NextAuth - Verification Tokens
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// =============================================================================
// CLIENT PROFILE
// =============================================================================

model ClientProfile {
  id          String    @id @default(uuid())
  userId      String    @unique
  firstName   String
  lastName    String
  phone       String?
  dateOfBirth DateTime?
  gender      String?
  avatarUrl   String?
  address     String?
  city        String?
  country     String    @default("SA")

  // Medical
  bloodType       String?
  allergies       String[]
  chronicDiseases String[]

  // Soft delete
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  medicalRecords MedicalRecord[]
  instantConsultRequests InstantConsultRequest[]

  piCreditBalance Decimal @default(0) @db.Decimal(12, 4) // refund credit (π)

  @@index([userId])
  @@index([deletedAt])
  @@map("client_profiles")
}

// =============================================================================
// DOCTOR PROFILE
// =============================================================================

model DoctorProfile {
  id                    String         @id @default(uuid())
  userId                String         @unique
  firstName             String
  lastName              String
  avatarUrl             String?
  bio                   String?
  phone                 String?
  gender                String?
  dateOfBirth           DateTime?

  // Professional
  specialization        String
  subSpecialization     String?
  yearsOfExperience     Int            @default(0)
  languages             String[]       @default(["ar"])

  // License
  licenseNumber         String         @unique
  licenseImageUrl       String
  licenseExpiryDate     DateTime?
  licenseIssuingCountry String         @default("SA")

  // Approval
  approvalStatus        ApprovalStatus @default(PENDING)
  approvalNotes         String?
  approvedAt            DateTime?
  approvedBy            String?

  // Pi KYC
  piKycVerified         Boolean        @default(false)

  // Location
  city                  String?
  country               String         @default("SA")
  address               String?
  consultationFee       Decimal?       @db.Decimal(10, 2)

  // سياسة الدفع
  paymentPolicy         PaymentPolicy  @default(PAY_ON_SERVICE)
  depositPercentage     Decimal        @default(0) @db.Decimal(5, 2) // نسبة الإيداع %
  paymentDeadlineHours  Int            @default(24) // ساعات للدفع قبل الموعد

  // استشارة فورية
  acceptsInstantConsult       Boolean  @default(false)
  isOnlineForInstant          Boolean  @default(false)
  instantConsultFee           Decimal? @db.Decimal(10, 4)
  instantConsultDurationMinutes Int    @default(15)

  // Stats
  totalReviews          Int            @default(0)
  averageRating         Decimal        @default(0) @db.Decimal(3, 2)
  totalAppointments     Int            @default(0)
  piBalance             Decimal        @default(0) @db.Decimal(12, 4) // رصيد Pi بعد خصم عمولة المنصة

  // Soft delete
  deletedAt             DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  // Relations
  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentials   DoctorCredential[]
  facilities    DoctorFacility[]
  availability  Availability[]
  appointments  Appointment[]          @relation("DoctorAppointments")
  onCallShifts  OnCallShift[]
  departmentAssignments DepartmentDoctorAssignment[]
  reviews       Review[]
  publications  Publication[]
  transactions  Transaction[]          @relation("DoctorTransactions")

  // Verification
  verification          DoctorVerification?
  verificationSessions  VerificationSession[] @relation("DoctorVerificationSessions")
  fraudRefs             FraudReference[]      @relation("DoctorFraudRefs")
  verificationScores    VerificationScore[]   @relation("DoctorScores")
  fraudChecks           FraudCheck[]          @relation("DoctorFraudChecks")
  matchedFrauds         FraudCheck[]          @relation("MatchedDoctorFrauds")

  @@index([userId])
  @@index([specialization])
  @@index([approvalStatus])
  @@index([licenseNumber])
  @@index([city])
  @@index([deletedAt])

  referralsFrom  Referral[]      @relation("ReferralFrom")
  referralsTo    Referral[]      @relation("ReferralTo")
  medicalRecords MedicalRecord[]
  instantConsultRequests InstantConsultRequest[]
  withdrawalRequests     WithdrawalRequest[]

  @@map("doctor_profiles")
}

// شهادات الطبيب العلمية
model DoctorCredential {
  id           String    @id @default(uuid())
  doctorId     String
  title        String
  institution  String
  country      String
  year         Int
  documentUrl  String
  isVerified   Boolean   @default(false)
  verifiedAt   DateTime?

  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  doctor DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([deletedAt])
  @@map("doctor_credentials")
}

// علاقة Many-to-Many بين الطبيب والمنشأة
model DoctorFacility {
  id           String    @id @default(uuid())
  doctorId     String
  facilityId   String
  role         String?
  startDate    DateTime  @default(now())
  endDate      DateTime?
  isActive     Boolean   @default(true)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  doctor   DoctorProfile   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  facility FacilityProfile @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@unique([doctorId, facilityId])
  @@index([doctorId])
  @@index([facilityId])
  @@map("doctor_facilities")
}

// =============================================================================
// FACILITY PROFILE
// =============================================================================

model FacilityProfile {
  id               String         @id @default(uuid())
  userId           String         @unique
  name             String
  type             FacilityType
  description      String?
  logoUrl          String?
  coverUrl         String?

  // License & permits
  licenseNumber    String         @unique
  licenseDocUrl    String         // تصريح / ترخيص مزاولة رسمي
  ownershipDocUrl  String?        // صك ملكية أو عقد إيجار
  licenseExpiryDate DateTime?

  // Approval
  approvalStatus   ApprovalStatus @default(PENDING)
  approvalNotes    String?
  approvedAt       DateTime?
  approvedBy       String?

  // Contact
  phone            String?
  email            String?
  website          String?

  // Location
  address          String
  city             String
  country          String         @default("SA")
  latitude         Decimal?       @db.Decimal(10, 8)
  longitude        Decimal?       @db.Decimal(11, 8)

  // Stats
  totalReviews     Int            @default(0)
  averageRating    Decimal        @default(0) @db.Decimal(3, 2)

  // Soft delete
  deletedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  // Relations
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctors      DoctorFacility[]
  appointments Appointment[]    @relation("FacilityAppointments")
  reviews      Review[]
  availability Availability[]
  departments  FacilityDepartment[]
  onCallShifts OnCallShift[]

  @@index([userId])
  @@index([type])
  @@index([approvalStatus])
  @@index([city])
  @@index([licenseNumber])
  @@index([deletedAt])
  @@map("facility_profiles")
}

// =============================================================================
// FACILITY DEPARTMENTS & ON-CALL
// =============================================================================

model FacilityDepartment {
  id          String   @id @default(uuid())
  facilityId  String
  code        String?
  name        String
  nameEn      String?
  icon        String?
  floor       String?
  phone       String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  facility     FacilityProfile              @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  onCallShifts OnCallShift[]
  doctors      DepartmentDoctorAssignment[]

  @@unique([facilityId, code])
  @@index([facilityId])
  @@index([isActive])
  @@map("facility_departments")
}

model DepartmentDoctorAssignment {
  id           String   @id @default(uuid())
  departmentId String
  doctorId     String
  role         String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department FacilityDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  doctor     DoctorProfile      @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([departmentId, doctorId])
  @@index([doctorId])
  @@map("department_doctor_assignments")
}

model OnCallShift {
  id           String          @id @default(uuid())
  facilityId   String
  departmentId String
  doctorId     String
  startsAt     DateTime
  endsAt       DateTime
  shiftType    OnCallShiftType @default(MORNING)
  notes        String?
  isPublished  Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  facility   FacilityProfile    @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  department FacilityDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  doctor     DoctorProfile      @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([facilityId, startsAt, endsAt])
  @@index([departmentId])
  @@index([doctorId])
  @@map("on_call_shifts")
}

// =============================================================================
// AVAILABILITY
// =============================================================================

model Availability {
  id          String    @id @default(uuid())
  doctorId    String?
  facilityId  String?
  dayOfWeek   DayOfWeek
  startTime   String
  endTime     String
  slotMinutes Int       @default(30)
  isActive    Boolean   @default(true)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  doctor   DoctorProfile?   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  facility FacilityProfile? @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([facilityId])
  @@map("availabilities")
}

// =============================================================================
// APPOINTMENTS
// =============================================================================

model Appointment {
  id          String            @id @default(uuid())
  clientId    String
  doctorId    String?
  facilityId  String?
  type        AppointmentType   @default(IN_PERSON)
  status      AppointmentStatus @default(PENDING)

  scheduledAt DateTime
  duration    Int               @default(30)
  notes       String?
  reason      String?

  // Results
  doctorNotes    String?
  cancelReason   String?
  cancelledBy    String?

  // Payment
  fee               Decimal?       @db.Decimal(10, 2)
  depositAmount     Decimal?       @db.Decimal(10, 2) // مبلغ الإيداع المدفوع
  isPaid            Boolean        @default(false)
  isDepositPaid     Boolean        @default(false)
  paidAt            DateTime?

  // Soft delete
  deletedAt   DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relations
  client       User              @relation("ClientAppointments", fields: [clientId], references: [id])
  doctor       DoctorProfile?    @relation("DoctorAppointments", fields: [doctorId], references: [id])
  facility     FacilityProfile?  @relation("FacilityAppointments", fields: [facilityId], references: [id])
  review       Review?
  transactions Transaction[]

  @@index([clientId])
  @@index([doctorId])
  @@index([facilityId])
  @@index([status])
  @@index([scheduledAt])
  @@index([deletedAt])

  reminders     AppointmentReminder[]
  medicalRecord MedicalRecord?

  @@map("appointments")
}

// =============================================================================
// REVIEWS
// =============================================================================

model Review {
  id            String    @id @default(uuid())
  clientId      String
  doctorId      String?
  facilityId    String?
  appointmentId     String? @unique
  instantConsultId  String? @unique

  rating      Int
  comment     String?
  isVisible   Boolean   @default(true)

  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  client      User             @relation(fields: [clientId], references: [id])
  doctor      DoctorProfile?   @relation(fields: [doctorId], references: [id])
  facility    FacilityProfile? @relation(fields: [facilityId], references: [id])
  appointment     Appointment?           @relation(fields: [appointmentId], references: [id])
  instantConsult  InstantConsultRequest? @relation(fields: [instantConsultId], references: [id])

  @@index([clientId])
  @@index([doctorId])
  @@index([facilityId])
  @@index([rating])
  @@index([deletedAt])
  @@map("reviews")
}

// =============================================================================
// PUBLICATIONS
// =============================================================================

model Publication {
  id          String            @id @default(uuid())
  doctorId    String
  title       String
  summary     String?
  content     String?
  type        PublicationType   @default(ARTICLE)
  status      PublicationStatus @default(DRAFT)
  tags        String[]
  coverUrl    String?
  publishedAt DateTime?

  viewCount   Int               @default(0)
  likeCount   Int               @default(0)

  deletedAt   DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  doctor DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([type])
  @@index([status])
  @@index([publishedAt])
  @@index([deletedAt])
  @@map("publications")
}

model PaidAdvertisement {
  id              String          @id @default(uuid())
  title           String
  description     String?
  imageUrl        String?
  linkUrl         String
  advertiserName  String
  advertiserEmail String?
  advertiserPhone String?
  requesterUserId String?
  placement       PaidAdPlacement @default(HOME_SIDEBAR)
  adPlan          AdPlan          @default(MONTHLY)
  status          PaidAdStatus    @default(PENDING_PAYMENT)
  pricePi         Decimal?        @db.Decimal(10, 4)
  durationDays    Int?
  piPaymentId     String?
  piTxHash        String?
  paidAt          DateTime?
  rejectionReason String?
  reviewedBy      String?
  reviewedAt      DateTime?
  startsAt        DateTime?
  endsAt          DateTime?
  clickCount      Int             @default(0)
  sortOrder       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status, placement, sortOrder])
  @@index([startsAt, endsAt])
  @@map("paid_advertisements")
}

// إعدادات أسعار الإعلانات — يتحكم بها المالك
model AdSettings {
  id                    String   @id @default(uuid())
  sidebarWeeklyPricePi  Decimal  @default(10) @db.Decimal(10, 4)
  sidebarMonthlyPricePi Decimal  @default(25) @db.Decimal(10, 4)
  defaultDurationDays   Int      @default(30)
  isAcceptingRequests   Boolean  @default(true)
  updatedBy             String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("ad_settings")
}

// =============================================================================
// NOTIFICATIONS
// =============================================================================

model Notification {
  id        String    @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String
  data      Json?
  isRead    Boolean   @default(false)
  readAt    DateTime?

  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// =============================================================================
// PREMIO (نظام البريميو)
// =============================================================================

// إعدادات أسعار البريميو - يتحكم بها المالك
model PremioSettings {
  id                 String   @id @default(uuid())
  monthlyPrice       Decimal  @db.Decimal(10, 4) // سعر الشهري بـ Pi
  yearlyPrice        Decimal  @db.Decimal(10, 4) // سعر السنوي بـ Pi
  lifetimePrice      Decimal  @db.Decimal(10, 4) // سعر مدى الحياة بـ Pi
  isMonthlyEnabled   Boolean  @default(true)     // تفعيل/تعطيل الشهري
  isYearlyEnabled    Boolean  @default(true)     // تفعيل/تعطيل السنوي
  isLifetimeEnabled  Boolean  @default(true)     // تفعيل/تعطيل مدى الحياة
  updatedBy          String   // userId المالك
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("premio_settings")
}

// سجل البريميو لكل مستخدم
model Premio {
  id          String       @id @default(uuid())
  userId      String
  type        PremioType
  status      PremioStatus @default(ACTIVE)
  startDate   DateTime     @default(now())
  expiryDate  DateTime?    // null = مدى الحياة
  pricePaid   Decimal?     @db.Decimal(10, 4) // كم دفع بـ Pi
  txHash      String?      // hash المعاملة في Pi Network
  giftedBy    String?      // userId المالك إذا كانت هدية مجانية
  notes       String?      // ملاحظة المالك عند منح المجاني

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([expiryDate])
  @@map("premios")
}

// =============================================================================
// TRANSACTIONS (المعاملات المالية)
// =============================================================================

model Transaction {
  id              String            @id @default(uuid())
  userId          String            // من دفع
  doctorId        String?           // من استلم (إن وجد)
  appointmentId   String?           // مرتبط بموعد

  type            TransactionType
  status          TransactionStatus @default(PENDING)

  amountTotal     Decimal           @db.Decimal(10, 4) // المبلغ الكلي بـ Pi
  platformFee     Decimal           @db.Decimal(10, 4) // نسبة المنصة
  receiverAmount  Decimal           @db.Decimal(10, 4) // مبلغ المستلم

  payerWallet     String?           // محفظة الدافع
  receiverWallet  String?           // محفظة المستلم

  txHash          String?           // Hash في Pi Blockchain
  notes           String?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user        User          @relation("UserTransactions", fields: [userId], references: [id])
  doctor      DoctorProfile? @relation("DoctorTransactions", fields: [doctorId], references: [id])
  appointment Appointment?  @relation(fields: [appointmentId], references: [id])

  @@index([userId])
  @@index([doctorId])
  @@index([appointmentId])
  @@index([status])
  @@index([type])
  @@map("transactions")
}

model WithdrawalRequest {
  id              String           @id @default(uuid())
  doctorId        String
  userId          String
  amount          Decimal          @db.Decimal(12, 4)
  status          WithdrawalStatus @default(PENDING)
  piUid           String
  piUsername      String?
  piPaymentId     String?
  toAddress       String?
  txHash          String?
  transactionId   String?          @unique
  rejectionReason String?
  reviewedBy      String?
  reviewedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  doctor DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  user   User          @relation("UserWithdrawals", fields: [userId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("withdrawal_requests")
}

// =============================================================================
// ACTIVITY LOG (سجل النشاطات)
// =============================================================================

model ActivityLog {
  id          String       @id @default(uuid())
  actorId     String       // من قام بالعملية
  action      ActivityType
  targetType  String       // USER / DOCTOR / FACILITY / PREMIO
  targetId    String       // معرف الهدف
  details     Json?        // تفاصيل إضافية
  ipAddress   String?      // IP المستخدم

  createdAt   DateTime     @default(now())

  actor User @relation("ActorLogs", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([action])
  @@index([targetId])
  @@index([createdAt])
  @@map("activity_logs")
