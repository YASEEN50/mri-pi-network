  doctorId              String?
  status                InstantConsultStatus @default(AWAITING_PAYMENT)
  reason                String?
  fee                   Decimal              @db.Decimal(10, 4)
  creditApplied         Decimal              @default(0) @db.Decimal(10, 4)
