  fromDoctor DoctorProfile @relation("ReferralFrom", fields: [fromDoctorId], references: [id])
  toDoctor   DoctorProfile @relation("ReferralTo",   fields: [toDoctorId],   references: [id])

  @@index([fromDoctorId])
  @@index([toDoctorId])
