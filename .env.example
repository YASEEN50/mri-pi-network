# =============================================================================

# Medical Platform — Environment Variables

# cp .env.example .env  ثم عدّل القيم

# =============================================================================



# ── Database (Neon / PostgreSQL) ─────────────────────────────────────────────

# رابط الاتصال عبر pooler (للتطبيق)

DATABASE_URL="postgresql://user:password@host-pooler.neon.tech/neondb?sslmode=require"

# رابط مباشر بدون pooler (لمigrations — مطلوب مع Neon)

DIRECT_URL="postgresql://user:password@host.neon.tech/neondb?sslmode=require"



# ── NextAuth ─────────────────────────────────────────────────────────────────

NEXTAUTH_SECRET="your-super-secret-key-minimum-32-characters-long"

# يجب أن يشير إلى نفس أصل التطبيق (مثلاً https://your-app.vercel.app)

NEXTAUTH_URL="http://localhost:3000"



# ── Google Cloud Vision (OCR — مطلوب للإنتاج) ───────────────────────────────

# مفتاح API من Google Cloud Console → Vision API

# بدونه: OCR يفشل ويُستخدم fallback (LICENSE_UPLOADED بدون استخراج نص)

# https://console.cloud.google.com/apis/library/vision.googleapis.com

GOOGLE_CLOUD_VISION_API_KEY="your-google-cloud-vision-api-key"



# ── Email (Resend) ───────────────────────────────────────────────────────────

RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"

EMAIL_FROM="noreply@medical-platform.com"



# ── Upstash Redis (Rate limiting — موصى به للإنتاج) ─────────────────────────

# أنشئ قاعدة Redis مجانية على https://upstash.com

# بدونها: يعمل fallback في الذاكرة (لا يُناسب Vercel serverless متعدد النسخ)

# REST URL من لوحة Upstash → Details

UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"

# REST Token من نفس الصفحة (Read-Write)

UPSTASH_REDIS_REST_TOKEN="your-upstash-token"



# ── Storage (استخدم r2 على Vercel — local للتطوير فقط) ─────────────────────

STORAGE_PROVIDER="r2"

R2_ACCOUNT_ID="your-cloudflare-account-id"

R2_ACCESS_KEY_ID="your-r2-access-key-id"

R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"

R2_BUCKET_NAME="medical-platform"

R2_PUBLIC_URL="https://your-bucket.your-domain.com"



# ── Workers (OCR / face / fraud — مطلوب لاستدعاء /api/workers/*) ────────────

WORKER_SECRET="your-worker-secret-min-32-chars"



# ── Pi Network (اختياري — الدخول يعمل بدون PI_API_KEY عبر Bearer /v2/me) ───

PI_API_KEY=""

PI_SANDBOX="true"

NEXT_PUBLIC_PI_SANDBOX="true"



# ── Admin (اختياري) ──────────────────────────────────────────────────────────

ADMIN_EMAIL="admin@medical-platform.com"



# ── App ──────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_URL="http://localhost:3000"

NEXT_PUBLIC_APP_NAME="Medical Platform"



# ── Audit Log HMAC ───────────────────────────────────────────────────────────

AUDIT_LOG_SECRET="your-audit-secret-min-32-chars"



# ── Cron (Vercel Cron — يحمي /api/cron/*) ────────────────────────────────────

CRON_SECRET="your-cron-secret-key"



# ── DeepFace (اختياري — للتحقق من الوجه في الإنتاج) ────────────────────────

DEEPFACE_SERVICE_URL=""

DEEPFACE_SERVICE_SECRET="your-deepface-secret"



# ── Redis (اختياري — fraud intelligence، بديل عن Upstash) ───────────────────

REDIS_URL=""

