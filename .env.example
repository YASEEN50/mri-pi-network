# =============================================================================
# Medical Platform — Environment Variables
# cp .env.example .env  ثم عدّل القيم
# =============================================================================

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/medical_platform?schema=public"

# NextAuth
NEXTAUTH_SECRET="your-super-secret-key-minimum-32-characters-long"
# يجب أن يشير إلى نفس أصل التطبيق (مثلاً https://your-domain.com في الإنتاج)
# يُستخدم لاستدعاء عمال OCR/face/fraud داخلياً من upload-license
NEXTAUTH_URL="http://localhost:3000"

# Pi Network
PI_APP_ID="your-pi-app-id"
PI_API_KEY="your-pi-api-key"
PI_WALLET_PRIVATE_KEY="your-wallet-private-key"
PI_SANDBOX="true"

# Storage (local | r2)
STORAGE_PROVIDER="local"

# Cloudflare R2 (required when STORAGE_PROVIDER=r2)
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="medical-platform"
R2_PUBLIC_URL="https://your-bucket.your-domain.com"

# Email
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="noreply@medical-platform.com"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Medical Platform"
NEXT_PUBLIC_PI_SANDBOX="true"

# Cron Jobs
CRON_SECRET="your-cron-secret-key"

# Google Cloud Vision — استخراج نص الرخصة (مهلة 10 ثوانٍ)
# https://console.cloud.google.com/apis/library/vision.googleapis.com
GOOGLE_CLOUD_VISION_API_KEY="your-google-cloud-vision-api-key"

# Worker Authentication (internal API protection)
# مطلوب لاستدعاء عمال OCR و face و fraud من /api/doctor/upload-license و upload-face-v2
# بدون WORKER_SECRET: الرفع ينجح لكن المعالجة الآلية (OCR/وجه/احتيال) تُتخطى
WORKER_SECRET="your-worker-secret-min-32-chars"

# Audit Log HMAC Signing
AUDIT_LOG_SECRET="your-audit-secret-min-32-chars"

# DeepFace Service (Railway) — للتحقق من الوجه في الإنتاج
# اتركه فارغاً لاستخدام الـ fallback المحلي في التطوير
DEEPFACE_SERVICE_URL=""
DEEPFACE_SERVICE_SECRET="your-deepface-secret"

# Azure Face API (بديل لـ DeepFace — اختياري)
AZURE_FACE_ENDPOINT=""
AZURE_FACE_API_KEY=""

# QStash (Upstash) — لـ worker queuing في الإنتاج
# اتركه فارغاً لاستخدام fire-and-forget في التطوير
QSTASH_URL=""
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""

# Redis (اختياري — fraud intelligence)
REDIS_URL=""

# Upstash Redis — Rate limiting (@upstash/ratelimit)
# بدونها: fallback في الذاكرة بنفس الحدود
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"
