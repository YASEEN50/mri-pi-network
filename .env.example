# =============================================================================
# Medical Platform — Environment Variables (copy to .env)
# =============================================================================

# Database (Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="generate-a-long-random-string-32-chars-min"
NEXTAUTH_URL="http://localhost:3000"

# Storage — use `local` for dev, `r2` on Vercel
STORAGE_PROVIDER="local"

# Cloudflare R2 (required when STORAGE_PROVIDER=r2)
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL="https://pub-xxxxx.r2.dev"
R2_ENDPOINT="https://111b05170d4f3edce3a50012d9a04ac2.r2.cloudflarestorage.com"

# Optional legacy fallback if R2_ENDPOINT is unset
# R2_ACCOUNT_ID=""

# Workers (OCR / face / fraud)
WORKER_SECRET="generate-a-long-random-string"

# Google Cloud Vision (license OCR)
GOOGLE_CLOUD_VISION_API_KEY=""

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="noreply@yourdomain.com"

# Rate limiting (optional — in-memory fallback if unset)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Pi Network
PI_API_KEY=""
NEXT_PUBLIC_PI_SANDBOX="true"
PI_SANDBOX="true"

# Audit
AUDIT_LOG_SECRET="generate-a-long-random-string"
