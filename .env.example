# =============================================================================
# Medical Platform — Environment Variables
# cp .env.example .env  ثم عدّل القيم
# =============================================================================

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/medical_platform?schema=public"

# NextAuth
NEXTAUTH_SECRET="your-super-secret-key-minimum-32-characters-long"
NEXTAUTH_URL="http://localhost:3000"

# Pi Network
PI_APP_ID="your-pi-app-id"
PI_API_KEY="your-pi-api-key"
PI_WALLET_PRIVATE_KEY="your-wallet-private-key"
PI_SANDBOX="true"

# Storage (local | r2)
STORAGE_PROVIDER="local"

# Cloudflare R2 (required when STORAGE_PROVIDER=r2)
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="medical-platform"
R2_PUBLIC_URL="https://your-bucket.your-domain.com"

# Email
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="noreply@medical-platform.com"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Medical Platform"
NEXT_PUBLIC_PI_SANDBOX="true"
